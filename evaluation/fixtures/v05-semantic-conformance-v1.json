      "content": "class ImportedBase:\n    pass\n\nclass UnimportedBase:\n    pass\n"
    },
    {
      "path": "python/pkg/inheritance.py",
      "content": "from pkg.base import ImportedBase\n\nclass ImportedChild(ImportedBase):\n    pass\n"
    },
    {
      "path": "python/pkg/unimported.py",
      "content": "class UnimportedChild(UnimportedBase):\n    pass\n"
    },
    {
      "path": "python/pkg/bindings.py",
      "content": "from pkg.target import py_target\nimport pkg.target\n\ndef shadowed(py_target):\n    return py_target()\n\ndef dotted():\n    return pkg.target.py_target()\n"
    },
    {
      "path": "go/receiver/receiver.go",
      "content": "package receiver\ntype A struct{}\ntype B struct{}\nfunc (A) Run() int { return 1 }\nfunc (B) Run() int { return 2 }\nfunc CallA(value A) int { return value.Run() }\n"
    },
    {
      "path": "go/receiver/receiver_test.go",
      "content": "package receiver\nfunc TestCaller() int { return CallA(A{}) }\n"
    },
    {
      "path": "go/receiver/excluded.go",
      "content": "//go:build contextmesh_never\n\npackage receiver\nfunc ExcludedByBuildConstraint() int { return 0 }\n"
    }
  ],
