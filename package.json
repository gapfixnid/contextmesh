{
  "name": "contextmesh",
  "version": "0.1.0",
  "description": "Local-first MCP code intelligence and long-term memory server",
  "type": "module",
  "bin": {
    "contextmesh": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.18 <24.19"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "tsx scripts/benchmark.ts",
    "evaluate:quality": "tsx scripts/evaluate-quality.ts",
    "fetch:semantic-smoke-model": "tsx scripts/fetch-semantic-smoke-model.ts",
    "smoke:semantic": "tsx scripts/smoke-semantic.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.check.json --noEmit",
    "lint": "eslint src tests scripts --max-warnings=0",
    "check": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "code-intelligence",
    "memory",
    "sqlite",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "ignore": "^7.0.5",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.15"
  }
}
